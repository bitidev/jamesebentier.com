<%
  set_meta_tags(
    title: @post.title,
    description: @post.description,
    canonical: post_url(@post.slug),
    og: { url: post_url(@post.slug), image: "https://jamesebentier.com/#{@post.image}" },
    twitter: { image: "https://jamesebentier.com/#{@post.image}" }
  )
%>
<%# Terminal-identity redesign (#1226): article reading column. No hero image -- the
    design reference's Post detail screen doesn't render one (the site's imagery-free
    terminal aesthetic), unlike the pre-redesign template which showed @post.image
    when present. Medium-syndication callout (#1185) keeps its existing copy/behavior,
    just restyled into the bordered callout the design doc calls for. %>
<article class="max-w-[740px] mx-auto px-8 pt-12 pb-[88px] font-sans text-lg leading-[1.7]">
  <%= link_to "cd ../writing ←", posts_path, class: "font-mono text-[13px] text-base-content/50 no-underline hover:text-primary inline-block mb-7" %>

  <p class="font-mono text-[13px] text-base-content/50 mb-3.5">
    <%# Glyph is decorative (aria-hidden); the visible "<kind> · date · N min" text below
        already conveys the kind to assistive tech, so no separate sr-only label here (a
        duplicate would make screen readers announce the kind twice). %>
    <span class="text-primary" aria-hidden="true"><%= @post.kind_glyph %></span>
    <%= @post.kind_label.downcase %> &middot; <%= @post.published_at.strftime("%Y-%m-%d") %> &middot; <%= @post.reading_time %> min
    <% @post.tags.each do |tag| %>
      &middot; #<%= tag %>
    <% end %>
  </p>

  <h1 class="font-mono text-4xl leading-[1.25] font-bold mb-4"><%= @post.title %></h1>
  <p class="text-xl text-base-content/70 mb-5"><%= @post.excerpt %></p>

  <% if @post.medium_url.present? %>
    <p class="font-mono text-[13px] text-base-content/50 border-l-2 border-primary pl-3.5 mb-11">
      <%= link_to "Also on Medium", @post.medium_url, class: "text-primary no-underline hover:underline", target: "_blank", rel: "noopener noreferrer" %>
    </p>
  <% end %>

  <div class="prose max-w-none">
    <%= render_markdown(@post.content) %>
  </div>

  <div class="border border-base-300 bg-base-200 rounded-[10px] p-6 md:p-7 flex items-center gap-6 flex-wrap font-mono mt-12">
    <div class="flex-1 min-w-[240px]">
      <p class="text-[13px] text-primary mb-1.5"># subscribe</p>
      <p class="font-sans text-base text-base-content/70 m-0">Occasional writing on systems &amp; craft — no spam.</p>
    </div>
    <div class="flex-1 min-w-[240px]">
      <%= render "components/newsletter_signup", source: "post" %>
    </div>
  </div>
</article>
