<%
  set_meta_tags(
    title: @post.title,
    description: @post.description,
    canonical: post_url(@post.slug),
    og: { url: post_url(@post.slug), image: "https://jamesebentier.com/#{@post.image}" },
    twitter: { image: "https://jamesebentier.com/#{@post.image}" }
  )
%>
<main class="mx-auto p-4">
  <article class="flex justify-center">
    <div class="bg-base-100 rounded shadow-lg px-12 py-6 prose lg:prose-base lg:w-full lg:max-w-screen-lg">
      <%- if @post.image %>
      <figure class="flex justify-center">
        <img src="<%= @post.image %>" alt="<%= @post.title %>" class="rounded bg-base-200 max-h-72">
      </figure>
      <% end %>
      <h1 class="font-mono text-3xl font-bold mb-4"><%= @post.title %></h1>

      <%# Metadata row (R5): kind badge, tag pills, published date, reading time -- all via
          the shared P1.1 components, in this order. %>
      <div class="flex flex-wrap items-center gap-3 mb-4 not-prose">
        <%= render "components/pill", label: @post.kind_label, variant: :kind %>
        <% @post.tags.each do |tag| %>
          <%= render "components/pill", label: tag, variant: :tag %>
        <% end %>
        <span class="text-sm text-base-content/70">
          <time datetime="<%= @post.published_at.iso8601 %>"><%= @post.published_at.strftime("%B %d, %Y") %></time>
          &middot; <%= @post.reading_time %> min read
        </span>
        <span class="text-sm text-base-content/70">By James Ebentier</span>
      </div>

      <p class="text-lg text-base-content/80"><%= @post.excerpt %></p>

      <div>
        <%= render_markdown(@post.content) %>
      </div>
    </div>
  </article>
</main>
