<% content_for :head do %>
  <%= auto_discovery_link_tag(:rss, posts_url(format: "rss")) %>
<% end %>

<%
  set_meta_tags(
    title: 'Writing',
    description: "Notes and Deep Dives from James Ebentier on software, systems, and building things.",
  )
%>

<%# Terminal-identity redesign (#1226): the full post index as a directory listing.
    Kind filter (D10): plain server-rendered query-string links, no JS -- whitelisted
    server-side via Post.by_kind (R2), same mechanism as before the redesign, just
    restyled into --all/--notes/--deep-dives pills. %>
<% current_kind = params[:kind] %>
<% posts = Post.published.by_kind(current_kind).order(published_at: :desc).to_a %>

<div class="max-w-[1088px] mx-auto px-8 pt-14 pb-[72px] font-mono">
  <p class="text-sm mb-2.5"><span class="text-primary">james@ebentier:~</span>$ ls ~/writing</p>
  <h1 class="text-4xl font-bold mb-6">Writing</h1>

  <nav class="flex items-center gap-2.5 mb-7 text-[13px] flex-wrap" aria-label="Filter by kind">
    <%= link_to "--all", posts_path,
          class: "rounded-md px-3 py-1.5 whitespace-nowrap no-underline #{current_kind.blank? ? 'bg-primary text-primary-content font-bold' : 'border border-base-300 text-base-content/70 hover:border-primary hover:text-primary'}" %>
    <%= link_to "--notes", posts_path(kind: "note"),
          class: "rounded-md px-3 py-1.5 whitespace-nowrap no-underline #{current_kind == 'note' ? 'bg-primary text-primary-content font-bold' : 'border border-base-300 text-base-content/70 hover:border-primary hover:text-primary'}" %>
    <%= link_to "--deep-dives", posts_path(kind: "deep_dive"),
          class: "rounded-md px-3 py-1.5 whitespace-nowrap no-underline #{current_kind == 'deep_dive' ? 'bg-primary text-primary-content font-bold' : 'border border-base-300 text-base-content/70 hover:border-primary hover:text-primary'}" %>
    <span class="ml-auto text-base-content/50 whitespace-nowrap">--sort=date ↓ &middot; <%= posts.size %> entries</span>
  </nav>

  <div class="border-t border-base-300">
    <% posts.each do |post| %>
      <%= link_to post_url(slug: post.slug), class: "flex items-baseline gap-4 py-3.5 px-2 border-b border-base-300 no-underline hover:bg-base-200" do %>
        <span class="w-[100px] shrink-0 text-[13px] text-base-content/50"><%= post.published_at.strftime("%Y-%m-%d") %></span>
        <span class="shrink-0 text-[13px] text-primary" aria-hidden="true"><%= post.kind_glyph %></span>
        <span class="sr-only"><%= post.kind_label %></span>
        <span class="flex-1 text-base font-bold min-w-0 truncate hover:text-primary"><%= post.title %></span>
        <% if post.tags.first.present? %>
          <span class="shrink-0 text-xs text-base-content/50 whitespace-nowrap">#<%= post.tags.first %></span>
        <% end %>
        <span class="w-14 shrink-0 text-right text-[13px] text-base-content/50"><%= post.reading_time %> min</span>
      <% end %>
    <% end %>
  </div>

  <p class="text-[13px] text-base-content/50 mt-5 px-2">
    <span class="text-primary" aria-hidden="true">◆</span> deep dive — a worked-through system or argument
    &nbsp;&middot;&nbsp;
    <span class="text-primary" aria-hidden="true">◇</span> note — a thought, reaction, or TIL. When in doubt, it's a note.
  </p>
</div>
