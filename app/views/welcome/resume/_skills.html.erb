<%#
  Resume skills -- terminal-identity redesign (#1226): flat, wrapping mono chip tags
  from resume.yml skills[].keywords (design doc's Resume section). The prior per-group
  level bars (style_for_level, now removed from ResumeHelper) are dropped along with
  them -- they relied on hardcoded hex colors and the design's skills band has no level
  indicator, just the keyword chips themselves.
%>
<div>
  <h2 class="flex items-baseline gap-3 mb-4.5">
    <span class="font-mono text-[15px] font-bold text-primary">## skills</span>
    <span class="flex-1 h-px bg-base-300" aria-hidden="true"></span>
  </h2>
  <div class="flex flex-wrap gap-2 font-mono text-[13px]">
    <% skills.each do |group| %>
      <% group[:keywords].each do |keyword| %>
        <span class="border border-base-300 bg-base-200 rounded-md px-2.5 py-1 text-base-content/70 lowercase"><%= keyword %></span>
      <% end %>
    <% end %>
  </div>
</div>
