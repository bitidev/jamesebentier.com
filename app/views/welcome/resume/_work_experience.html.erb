<%#
  Resume experience list -- terminal-identity redesign (#1226). Keeps the existing
  collapse_controller.js wiring (first entry expanded, click toggles highlights) rather
  than dropping it -- restyled to the design doc's date/title/company/blurb row shape
  (date span w-150 mono13/50, title 19/bold, company primary mono14, blurb sans16/70)
  instead of introducing a second, un-styled interaction path.
%>
<h2 class="flex items-baseline gap-3 mb-5">
  <span class="font-mono text-[15px] font-bold text-primary">## experience</span>
  <span class="flex-1 h-px bg-base-300" aria-hidden="true"></span>
</h2>
<div class="flex flex-col gap-8 mb-11">
  <% work.each_with_index do |data, index| %>
    <div data-controller="collapse">
      <div class="flex gap-6 items-start flex-wrap cursor-pointer" data-action="click->collapse#toggle">
        <div class="w-[150px] shrink-0 font-mono text-[13px] text-base-content/50 pt-1">
          <%= Date.parse(data[:startDate]).strftime('%Y') %> &mdash; <%= data[:endDate] ? Date.parse(data[:endDate]).strftime('%Y') : 'present' %>
        </div>
        <div class="flex-1 min-w-[280px]">
          <p class="text-[19px] font-bold m-0 mb-0.5 flex items-center gap-2">
            <i class="fa-solid <%= index.zero? ? 'fa-caret-down' : 'fa-caret-right' %> text-sm text-base-content/50 print:hidden" data-collapse="arrow" aria-hidden="true"></i>
            <%= data[:position] %>
          </p>
          <p class="font-mono text-sm text-primary mb-2.5"><%= data[:company] %></p>
          <p class="text-base text-base-content/70 m-0"><%= data[:summary] %></p>
        </div>
      </div>
      <div class="<%= index.zero? ? '' : 'hidden' %> md:ml-[174px] print:block" data-collapse="content">
        <% if data[:highlights] %>
          <ul class="list-square pl-5 mt-3 text-base-content/70 space-y-1.5">
            <% data[:highlights].each do |highlight| %>
              <li><%= highlight %></li>
            <% end %>
          </ul>
        <% end %>
      </div>
    </div>
  <% end %>
</div>
