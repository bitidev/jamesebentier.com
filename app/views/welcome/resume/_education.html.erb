<div>
  <h2 class="flex items-baseline gap-3 mb-4.5">
    <span class="font-mono text-[15px] font-bold text-primary">## education</span>
    <span class="flex-1 h-px bg-base-300" aria-hidden="true"></span>
  </h2>
  <% education.each do |data| %>
    <div class="mb-4">
      <p class="text-[17px] font-bold m-0 mb-0.5"><%= data[:studyType] %> <%= data[:area] %></p>
      <p class="font-mono text-[13px] text-base-content/50 m-0">
        <%= data[:institution] %> &middot; <%= Date.parse(data[:startDate]).strftime('%Y') %>&ndash;<%= data[:endDate] ? Date.parse(data[:endDate]).strftime('%Y') : 'present' %>
      </p>
    </div>
  <% end %>
</div>
