<%#
  Resume header row -- terminal-identity redesign (#1226). No download.pdf button: the
  design reference shows one, but this app has no PDF/print-download route, so it's
  omitted rather than link to a page that doesn't exist (the page itself is left
  print-friendly via ordinary browser printing instead). Subtitle years-of-experience
  is computed from the earliest `work` entry's startDate rather than a hardcoded
  number, so it never goes stale as resume.yml grows.
%>
<%
  earliest_year = work.map { |entry| Date.parse(entry[:startDate]).year }.min
  years_experience = earliest_year ? Date.current.year - earliest_year : nil
%>
<div class="mb-10">
  <p class="font-mono text-sm text-primary mb-2.5">james@ebentier:~$ cat resume.txt</p>
  <h1 class="font-mono text-[34px] font-bold mb-1.5"><%= basics[:name] %></h1>
  <p class="font-mono text-[15px] text-base-content/70 m-0">
    Software Architect &middot; <%= basics.dig(:location, :city) %>, <%= basics.dig(:location, :countryCode) %><% if years_experience %> &middot; <%= years_experience %>+ yrs<% end %>
  </p>
</div>
