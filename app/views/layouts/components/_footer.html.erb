<%# Terminal-identity redesign (#1226): full 3-column footer, rendered Home-only now
    (app/views/layouts/application.html.erb gates this partial behind
    ApplicationHelper#show_full_footer?) -- interior pages end at the statusline.
    The shared work_with_me_cta CTA moved OUT of the footer; each page carries its own
    CTA block instead (see components/_work_with_me_cta.html.erb). %>
<footer class="border-t border-base-300 font-mono">
  <div class="max-w-[1088px] mx-auto px-8 py-12 grid gap-12 md:grid-cols-[1.2fr_0.7fr_1.3fr]">
    <div>
      <p class="text-[15px] font-bold mb-2.5">
        <span class="text-primary" aria-hidden="true">❯</span> james@ebentier
      </p>
      <p class="text-[13px] text-base-content/50 mb-4">
        &copy; <%= Date.today.year %> James Ebentier &middot; Berlin<br>
        <%= link_to "Impressum", impressum_path, class: "hover:text-primary" %>
        &middot;
        <%= link_to "Privacy", privacy_path, class: "hover:text-primary" %>
      </p>
      <div class="flex gap-4 text-[17px] text-base-content/70">
        <a href="https://github.com/jebentier" rel="noreferrer" target="_blank" title="jebentier github account" class="hover:text-primary"><%= social_profile_icon :github %></a>
        <a href="https://linkedin.com/in/jebentier" rel="noreferrer" target="_blank" title="jebentier linkedin account" class="hover:text-primary"><%= social_profile_icon :linkedin %></a>
        <a href="https://twitter.com/jebentier" rel="noreferrer" target="_blank" title="jebentier twitter account" class="hover:text-primary"><%= social_profile_icon :twitter %></a>
        <a href="<%= posts_url(format: "rss") %>" target="_blank" title="writing rss feed" class="hover:text-primary"><i class="fa-solid fa-square-rss text-base"></i></a>
      </div>
    </div>

    <div class="text-sm">
      <p class="text-[13px] text-base-content/50 mb-2.5"># sitemap</p>
      <div class="flex flex-col gap-2">
        <%= link_to "/writing", posts_url, class: "text-base-content/70 hover:text-primary no-underline" %>
        <%= link_to "/projects", projects_url, class: "text-base-content/70 hover:text-primary no-underline" %>
        <%= link_to "/about", about_path, class: "text-base-content/70 hover:text-primary no-underline" %>
        <%= link_to "/resume", resume_path, class: "text-base-content/70 hover:text-primary no-underline" %>
      </div>
    </div>

    <div>
      <p class="text-[13px] text-base-content/50 mb-2.5"># newsletter &mdash; occasional writing on systems &amp; craft</p>
      <%= render "components/newsletter_signup", source: "footer" %>
    </div>
  </div>
</footer>
