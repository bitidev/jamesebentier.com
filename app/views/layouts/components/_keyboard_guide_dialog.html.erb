<%# `?` keyboard-guide overlay (R10). This increment ships only the open/close
    plumbing -- a bare toggle proving the mode-dispatch foundation; the full bindings
    reference table (every binding shipped across R3-R8, plus the command registry's
    v1 list) is a later increment's scope.

    Native <dialog>: the one deliberate focus-trap exception in this feature (R11) --
    it gives focus-containment, Esc-to-close, and ::backdrop semantics from the browser
    for free, which is exactly right for a full "here are the bindings" help panel.
    COMMAND/SEARCH (later increments) stay plain, non-trapping bars, deliberately not
    <dialog>s. %>
<dialog
  id="keyboard-guide-dialog"
  data-keyboard-nav-target="guideDialog"
  class="font-mono backdrop:bg-black/50 rounded-box p-6 max-w-lg w-[90vw] text-base-content bg-base-100"
>
  <h2 class="text-lg font-semibold mb-4">Keyboard bindings</h2>
  <p class="text-sm text-base-content/70 mb-6">
    This site supports modal, vim-style keyboard navigation. The full bindings
    reference lands here as later increments of this feature ship.
  </p>
  <form method="dialog">
    <button type="submit" class="btn btn-sm">Close</button>
  </form>
</dialog>
