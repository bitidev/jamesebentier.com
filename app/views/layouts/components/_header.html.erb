<header class='w-full shadow mb-8 print:hidden'>
  <div class='flex w-full max-w-7xl mx-auto px-8 py-4 print:hidden'>
    <img src="/favicon.ico" alt="James Ebentier" class='h-9 justify-self-start' />
    <ul class='flex flex-row list-none ml-auto content-center items-center justify-end my-auto'>
      <li class='ml-4'><%= link_to 'Home', root_url, class: current_page?(root_path) ? 'text-primary cursor-default' : 'link link-hover' %></li>
      <li class='ml-4'><%= link_to 'Blog', posts_url, class: current_page?(posts_path) ? 'text-primary cursor-default' : 'link link-hover' %></li>
      <li class='ml-4'><%= link_to 'Projects', projects_url, class: current_page?(projects_url) ? 'text-primary cursor-default' : 'link link-hover' %></li>
      <li class='ml-4'><%= link_to 'Resume', resume_path, class: current_page?(resume_url) ? 'text-primary cursor-default' : 'link link-hover' %></li>
      <%# Terminal-styled theme switcher (R6). data-theme-picker-target="select" is read
          by app/javascript/controllers/theme_picker_controller.js; the render-blocking
          inline script in application.html.erb's <head> is what applies the visitor's
          stored choice on load (before this control even connects). %>
      <li class='ml-4 flex items-center gap-1 font-mono text-sm' data-controller='theme-picker'>
        <label for='theme-picker-select' class='sr-only'>Theme</label>
        <span aria-hidden='true' class='text-primary'>&gt;</span>
        <select
          id='theme-picker-select'
          data-theme-picker-target='select'
          data-action='theme-picker#change'
          class='select select-ghost select-sm font-mono'
        >
          <option value='light'>light</option>
          <option value='dark'>dark</option>
          <option value='dracula'>dracula</option>
          <option value='nord'>nord</option>
          <option value='gruvbox'>gruvbox</option>
          <option value='catppuccin'>catppuccin</option>
        </select>
      </li>
    </ul>
  </div>
</header>
