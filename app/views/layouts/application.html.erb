<!DOCTYPE html>
<html>
  <head>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%=
      display_meta_tags(
        site: t('site.name'),
        separator: '|',
        reverse: true,
        follow: true,
        index: true,
        og: {
          title: :title,
          description: :description,
          type: 'website',
          site_name: :site,
          url: request.original_url,
          image: 'https://jamesebentier.com/logo192.png'
        },
        twitter: {
          card: 'summary_large_image',
          title: :title,
          description: :description,
          site: t('site.twitter_handle'),
          creator: t('site.owner_twitter_handle'),
          image: 'https://jamesebentier.com/logo192.png'
        }
      )
    %>

    <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico">
    <link rel="apple-touch-icon" href="/logo192.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/manifest.json" />

    <%# Sets [data-theme] from the visitor's stored preference before first paint, so a
        returning visitor never sees a flash of the wrong theme on load. Synchronous and
        render-blocking on purpose (no type="module", no defer/async) -- it must finish
        before the stylesheet below applies. Falls back to "light" (today's default) when
        no preference is stored yet. "theme" is the single documented localStorage key;
        app/javascript/controllers/theme_picker_controller.js is the only other place
        that reads/writes it. %>
    <script>
      (function () {
        var theme = 'light';
        try {
          theme = window.localStorage.getItem('theme') || 'light';
        } catch (e) {
          // localStorage can throw in some private-browsing modes; fall back to light.
        }
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
    <script src="https://kit.fontawesome.com/d7b2096eb7.js" crossorigin="anonymous"></script>
  </head>

  <%# data-controller="keyboard-nav" mounts the modal NORMAL/COMMAND/SEARCH keyboard
      layer once, site-wide (see app/javascript/controllers/keyboard_nav_controller.js).
      <body> is not data-turbo-permanent, so standard Turbo Drive visits
      disconnect/reconnect it -- and reset mode to NORMAL -- on every navigation, by
      design. %>
  <body data-controller="keyboard-nav analytics-visit">
    <%= render partial: 'layouts/components/header' %>
    <div class="max-w-screen-lg m-auto font-sans">
      <%# Flash messages for newsletter signup and other controller actions %>
      <% if flash[:notice].present? %>
        <div class="alert alert-success mx-4 mt-4" role="alert">
          <span><%= flash[:notice] %></span>
        </div>
      <% end %>
      <% if flash[:alert].present? %>
        <div class="alert alert-error mx-4 mt-4" role="alert">
          <span><%= flash[:alert] %></span>
        </div>
      <% end %>
      <%= yield %>
    </div>
    <%= render partial: 'layouts/components/footer' %>
    <%= render partial: 'layouts/components/keyboard_status_line' %>
    <%= render partial: 'layouts/components/keyboard_guide_dialog' %>
    <%= render partial: 'layouts/components/keyboard_command_bar' %>
    <%= render partial: 'layouts/components/keyboard_hint_overlay' %>
  </body>
</html>
