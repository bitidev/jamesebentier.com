<!DOCTYPE html>
<html>
  <head>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <%=
      display_meta_tags(
        site: t('site.name'),
        separator: '|',
        reverse: true,
        follow: true,
        index: true,
        # Site-wide default canonical (#1189): the query string is stripped so filtered
        # index views (?kind=note, ?status=beta) canonicalize back to their clean path.
        # A view that sets its own `canonical:` via set_meta_tags (e.g. writing/show)
        # overrides this default -- meta-tags values are last-set-wins.
        canonical: request.original_url.sub(/\?.*\z/, ''),
        og: {
          title: :title,
          description: :description,
          type: 'website',
          site_name: :site,
          url: request.original_url,
          image: "#{root_url}og-default.png"
        },
        twitter: {
          card: 'summary_large_image',
          title: :title,
          description: :description,
          site: t('site.twitter_handle'),
          creator: t('site.owner_twitter_handle'),
          image: "#{root_url}og-default.png"
        }
      )
    %>
    <%# Site-wide structured data (#1189 design doc): Person + WebSite on every page, each
        its own <script type="application/ld+json"> block. Post pages additionally emit
        BlogPosting from writing/show via content_for :head. %>
    <%= person_json_ld %>
    <%= website_json_ld %>

    <link rel="shortcut icon" type="image/x-icon" href="/favicon.ico">
    <link rel="apple-touch-icon" href="/logo192.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/manifest.json" />

    <%# Sets [data-theme] from the visitor's stored preference before first paint, so a
        returning visitor never sees a flash of the wrong theme on load. Synchronous and
        render-blocking on purpose (no type="module", no defer/async) -- it must finish
        before the stylesheet below applies. Falls back to "gruvbox" (today's default) when
        no preference is stored yet. "theme" is the single documented localStorage key;
        app/javascript/controllers/theme_picker_controller.js is the only other place
        that reads/writes it. %>
    <script>
      (function () {
        var theme = 'gruvbox';
        try {
          theme = window.localStorage.getItem('theme') || 'gruvbox';
        } catch (e) {
          // localStorage can throw in some private-browsing modes; fall back to gruvbox.
        }
        document.documentElement.setAttribute('data-theme', theme);
      })();
    </script>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
    <script src="https://kit.fontawesome.com/d7b2096eb7.js" crossorigin="anonymous"></script>
  </head>

  <%# data-controller="keyboard-nav" mounts the modal NORMAL/COMMAND/SEARCH keyboard
      layer once, site-wide (see app/javascript/controllers/keyboard_nav_controller.js).
      <body> is not data-turbo-permanent, so standard Turbo Drive visits
      disconnect/reconnect it -- and reset mode to NORMAL -- on every navigation, by
      design. %>
  <body data-controller="keyboard-nav analytics-visit">
    <%= render partial: 'layouts/components/header' %>
    <%# Terminal-identity redesign (#1226): each page now owns its own content-column
        max-width (1088px chrome / 760-900-740px reading columns per page), so this
        wrapper no longer forces a single site-wide max-w-screen-lg -- yield renders
        full-bleed and each view's own outermost element sets its own constrained,
        centered column. Flash messages get their own constrained wrapper so they never
        stretch edge-to-edge. %>
    <% if flash[:notice].present? %>
      <div class="max-w-[1088px] mx-auto px-8 mt-4">
        <div class="alert alert-success" role="alert">
          <span><%= flash[:notice] %></span>
        </div>
      </div>
    <% end %>
    <% if flash[:alert].present? %>
      <div class="max-w-[1088px] mx-auto px-8 mt-4">
        <div class="alert alert-error" role="alert">
          <span><%= flash[:alert] %></span>
        </div>
      </div>
    <% end %>
    <%= yield %>
    <%# Home-only full footer (design doc's Shared chrome > Footer section) -- interior
        pages end at the statusline below. %>
    <%= render partial: 'layouts/components/footer' if show_full_footer? %>
    <%= render partial: 'layouts/components/keyboard_status_line' %>
    <%= render partial: 'layouts/components/keyboard_guide_dialog' %>
    <%= render partial: 'layouts/components/keyboard_command_bar' %>
    <%= render partial: 'layouts/components/keyboard_hint_overlay' %>
  </body>
</html>
