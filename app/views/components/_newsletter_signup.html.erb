<%#
  Newsletter signup form partial -- terminal-identity redesign (#1226): a shell-prompt
  styled row ("$ subscribe" + transparent email input + a bordered "↵" submit button)
  inside a bordered rounded-md box, usable as both the footer's form and any inline/
  page-level form (source: "home"/"footer"/"post"/...).

  Locals:
    source: required — short string identifying where the form is rendered
            (e.g. "footer" / "home" / "post"). Written to Subscriber#consent_source.

  On submit, POSTs to /newsletter with email, consent checkbox, and the source.
  Consent checkbox links to /privacy per GDPR requirement. Flash messages (notice/
  alert) are handled by the layout; this partial only triggers a redirect-back with
  flash via NewslettersController#create.
%>
<%= form_with url: newsletters_path, method: :post, class: "flex flex-col gap-3 font-mono" do |f| %>
  <%= hidden_field_tag "subscriber[source]", local_assigns.fetch(:source, "unknown") %>

  <div class="flex items-center gap-2.5 border border-base-300 rounded-md px-3.5 py-2.5 bg-base-100">
    <span class="text-primary text-sm shrink-0" aria-hidden="true">$ subscribe</span>
    <label class="sr-only" for="subscriber_email_<%= source %>">Email address</label>
    <%= f.email_field :email,
          id: "subscriber_email_#{source}",
          name: "subscriber[email]",
          placeholder: "you@example.com",
          required: true,
          autocomplete: "email",
          class: "flex-1 min-w-0 bg-transparent outline-none border-none text-sm text-base-content" %>
    <button type="submit" aria-label="Subscribe" class="text-[13px] font-bold text-primary bg-transparent border border-primary rounded px-2.5 py-1 hover:bg-primary hover:text-primary-content">↵</button>
  </div>

  <label class="flex items-start gap-2 cursor-pointer text-xs text-base-content/50 font-sans leading-relaxed">
    <%= check_box_tag "subscriber[consent]", "1", false,
          required: true,
          class: "checkbox checkbox-xs mt-0.5 shrink-0" %>
    <span>
      I agree to receive occasional emails — see the
      <%= link_to "privacy policy", privacy_path, class: "text-primary" %>.
    </span>
  </label>
<% end %>
