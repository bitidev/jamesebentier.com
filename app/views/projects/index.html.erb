<% content_for :head do %>
  <%= auto_discovery_link_tag(:rss, projects_url(format: "rss")) %>
<% end %>

<%
  set_meta_tags(
    title: 'Projects',
    description: "Stay up-to-date with James Ebentier's latest projects released to the public through BiTi LLC",
  )
%>

<%# Page heading stays an <h1> (one per page); each project card's title is itself the
    focusable link to the show page (R3) -- the triple-link CTAs below it link elsewhere
    (or the same demo URL), so the title carries the card's keyboard/screen-reader-reachable
    "go to this project's page" duty that a dedicated "View Project" CTA used to. %>
<h1 class='font-mono text-3xl mb-4'>Recent Projects</h1>

<% projects = Project.by_status(params[:status]) %>

<%= render layout: "components/section" do %>
  <% if Project.count.zero? %>
    <%# Table-wide empty (R5.1): brand-new database, nothing to filter -- no filter row. %>
    <p class='font-mono'>Projects are coming soon &mdash; check back shortly.</p>
  <% else %>
    <nav class='flex gap-4 mb-6 font-mono text-sm' aria-label='Filter projects by status'>
      <%= link_to 'All', projects_path, class: params[:status].blank? ? 'text-primary cursor-default' : 'link link-hover' %>
      <% Project::STATUSES.each do |status| %>
        <%= link_to status, projects_path(status: status), class: params[:status] == status ? 'text-primary cursor-default' : 'link link-hover' %>
      <% end %>
    </nav>

    <% if projects.none? %>
      <%# Filtered-empty (R5.2): rows exist, but none match the selected status -- keep the
          filter row (including "All") visible so the visitor can clear the filter. %>
      <p class='font-mono'>No <%= params[:status] %> projects yet.</p>
    <% else %>
      <div class='grid grid-cols-1 md:grid-cols-3 gap-6'>
        <% projects.each do |project| %>
          <%= render layout: "components/card", locals: { href: project_url(slug: project.slug), image_url: project.image } do %>
            <h2 class='card-title font-mono text-xl'><%= link_to project.title, project_url(slug: project.slug) %></h2>
            <div>
              <%= render "components/pill", label: project.status, variant: :status %>
            </div>
            <p class='mb-0'><%= project.description %></p>
            <%# Triple-links, read -> demo -> source (R3). Demo (project.url) always renders;
                Read/Source render only when present. relative z-10 keeps these independently
                clickable above the card's stretched-link overlay. %>
            <div class='card-actions relative z-10 mt-2'>
              <% if project.read_url.present? %>
                <%= render "components/cta_button", label: "Read", href: project.read_url, style: :ghost %>
              <% end %>
              <%= render "components/cta_button", label: "Demo", href: project.url, style: :primary %>
              <% if project.source_url.present? %>
                <%= render "components/cta_button", label: "Source", href: project.source_url, style: :ghost %>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>
    <% end %>
  <% end %>
<% end %>
