<% content_for :head do %>
  <%= auto_discovery_link_tag(:rss, projects_url(format: "rss")) %>
<% end %>

<%
  set_meta_tags(
    title: 'Projects',
    description: "Stay up-to-date with James Ebentier's latest projects released to the public through BiTi LLC",
  )
%>

<%# Page heading stays an <h1> (one per page); each project card title is an <h2>
    beneath it. The section partial wraps the listing (R9) and provides the fade/slide-in
    motion + consistent spacing. Simple single-column stack -- the card grid/filters are
    P1.3's job, deliberately not pulled forward here. %>
<h1 class='font-mono text-3xl mb-4'>Recent Projects</h1>

<%= render layout: "components/section" do %>
  <div class='space-y-6'>
    <% Project.find_each do |project| %>
      <%= render layout: "components/card", locals: { href: project_url(slug: project.slug), image_url: project.image } do %>
        <h2 class='card-title font-mono text-xl'><%= project.title %></h2>
        <div>
          <%= render "components/pill", label: project.status, variant: :status %>
        </div>
        <p class='mb-0'><%= project.description %></p>
        <div class='card-actions relative z-10 mt-2'>
          <%= render "components/cta_button", label: "View Project", href: project_url(slug: project.slug), style: :primary %>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
