<% content_for :head do %>
  <%= auto_discovery_link_tag(:rss, projects_url(format: "rss")) %>
<% end %>

<%
  set_meta_tags(
    title: 'Projects',
    description: "Stay up-to-date with James Ebentier's latest projects released to the public through BiTi LLC",
  )
%>

<%# Terminal-identity redesign (#1226): each project as a terminal-window pane. Status
    filter (R4) reuses the existing Project.by_status/Project::STATUSES contract
    unchanged, just restyled into --all/--pre-launch/--beta/--live pills. %>
<div class="max-w-[1088px] mx-auto px-8 pt-14 pb-[72px] font-mono">
  <p class="text-sm mb-2.5"><span class="text-primary">james@ebentier:~</span>$ ls ~/projects</p>
  <h1 class="text-4xl font-bold mb-6">Projects</h1>

  <% if Project.count.zero? %>
    <%# Table-wide empty (R5.1): brand-new database, nothing to filter -- no filter row. %>
    <p>Projects are coming soon &mdash; check back shortly.</p>
  <% else %>
    <nav class="flex items-center gap-2.5 mb-7 text-[13px] flex-wrap" aria-label="Filter projects by status">
      <%= link_to "--all", projects_path,
            class: "rounded-md px-3 py-1.5 whitespace-nowrap no-underline #{params[:status].blank? ? 'bg-primary text-primary-content font-bold' : 'border border-base-300 text-base-content/70 hover:border-primary hover:text-primary'}" %>
      <% Project::STATUSES.each do |status| %>
        <%= link_to "--#{status.downcase}", projects_path(status: status),
              class: "rounded-md px-3 py-1.5 whitespace-nowrap no-underline #{params[:status] == status ? 'bg-primary text-primary-content font-bold' : 'border border-base-300 text-base-content/70 hover:border-primary hover:text-primary'}" %>
      <% end %>
    </nav>

    <% projects = Project.by_status(params[:status]).to_a %>
    <% if projects.none? %>
      <%# Filtered-empty (R5.2): rows exist, but none match the selected status -- keep
          the filter row (including "--all") visible so the visitor can clear it. %>
      <p>No <%= params[:status] %> projects yet.</p>
    <% else %>
      <div class="grid md:grid-cols-2 gap-6">
        <% projects.each do |project| %>
          <div class="border border-base-300 bg-base-200 rounded-[10px] overflow-hidden flex flex-col hover:border-primary">
            <div class="flex items-center gap-1.5 px-3.5 py-2.5 border-b border-base-300 text-[13px] text-base-content/50">
              <span class="w-2.5 h-2.5 rounded-full bg-error" aria-hidden="true"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-warning" aria-hidden="true"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-success" aria-hidden="true"></span>
              <span class="ml-2 truncate min-w-0">~/projects/<%= project.slug %></span>
              <span class="ml-auto shrink-0 <%= project.status_color_class %>">● <%= project.status.downcase %></span>
            </div>
            <div class="p-7 flex flex-col gap-3 flex-1">
              <h2 class="text-2xl font-bold m-0"><%= link_to project.title, project_url(slug: project.slug), class: "no-underline hover:text-primary" %></h2>
              <p class="text-base text-base-content/70 m-0 flex-1"><%= project.description %></p>
              <%# Triple-links, demo -> read -> source (R3/R6 precedent): demo (project.url)
                  always renders; read/source render only when present. %>
              <div class="flex gap-4 text-sm border-t border-base-300 pt-4">
                <%= link_to "[demo ↗]", project.url, class: "text-primary font-bold no-underline hover:underline" %>
                <% if project.read_url.present? %>
                  <%= link_to "[read]", project.read_url, class: "text-base-content/50 no-underline hover:text-primary" %>
                <% end %>
                <% if project.source_url.present? %>
                  <%= link_to "[source]", project.source_url, class: "text-base-content/50 no-underline hover:text-primary" %>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  <% end %>
</div>
