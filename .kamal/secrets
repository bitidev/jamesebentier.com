# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml. All secrets should be pulled from either
# password manager, ENV, or a file. DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.
#
# Values are resolved by Kamal via dotenv (variable + command substitution), typically sourced from a
# git-ignored .env in the repo root or the operator's shell environment. See
# docs/ops/kamal-first-deploy.md for the full list of variables to fill in before running `kamal setup`.

# GitHub Container Registry token (classic PAT, write:packages scope). See R5 / registry: in deploy.yml.
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Rails master key, used to decrypt config/credentials.yml.enc at boot.
RAILS_MASTER_KEY=${RAILS_MASTER_KEY:-$(cat config/master.key 2>/dev/null)}

# Postgres accessory credentials (POSTGRES_USER/POSTGRES_DB are set as env.clear in
# accessories.postgres — not secret — but the password is).
POSTGRES_PASSWORD=$POSTGRES_PASSWORD

# The app's DATABASE_URL, built from the same accessory credentials above so both sides
# always agree. "jamesebentier-site-postgres" is Kamal's default accessory hostname
# (<service>-<accessory>), reachable from the app container on Kamal's private network.
DATABASE_URL=postgres://jamesebentier_site:$POSTGRES_PASSWORD@jamesebentier-site-postgres:5432/jamesebentier_site_production
