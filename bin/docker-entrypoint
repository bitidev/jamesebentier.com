#!/bin/bash -e

# If running the rails server then create or migrate existing database, and seed it.
# Mirrors the two-step db:migrate db:seed the Heroku release phase (bin/release) used
# to run; db/seeds.rb is idempotent so re-running it on every boot/redeploy is safe.
if [ "${1}" == "./bin/rails" ] && [ "${2}" == "server" ]; then
  ./bin/rails db:prepare
  ./bin/rails db:seed
fi

exec "${@}"
